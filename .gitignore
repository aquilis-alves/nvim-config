# --- Neovim & Editors ---
*.swp
*.swo
*.swn
.netrwhist
undo/
/nvim/.neoconf.json
doc/tags

# --- Logs, Cache and Data ---
*.log
/nvim/cache/
/nvim/data/
/nvim/plugin/

# --- Development and Testing ---
.repro/
.tests/
debug/
foo.*
tt.*

# --- LaTeX (Auxiliary files generated by VimTeX/Latexmk) ---
# Ignore files generated during LaTeX document compilation
*.aux
*.fdb_latexmk
*.fls
*.synctex.gz
*.toc
*.out
*.bbl
*.blg
*.nav
*.snm
*.vrb
*.pdf

# --- Locks ---
